# m-trace — example environment file
#
# Diese Datei dokumentiert die Umgebungsvariablen, die das Compose-
# Lab und die einzelnen Services lesen. Sie enthält ausschließlich
# nicht geheime Beispielwerte. Reale Tokens, private URLs oder
# Credentials gehören NICHT hier rein.
#
# Verwendung:
#   cp .env.example .env
#   # .env nach Bedarf anpassen, dann:
#   make dev
#
# Vollständige Beschreibung: docs/user/local-development.md.

# -------------------------------------------------------------------
# API service (apps/api)
# -------------------------------------------------------------------
# Listen-Adresse innerhalb des Containers; Port-Mapping erfolgt in
# docker-compose.yml.
MTRACE_API_LISTEN_ADDR=:8080

# Persistenz-Modus: "sqlite" ist der Default ab 0.4.0 (ADR-0002 §8.1).
# Setze auf "inmemory", wenn Sessions bewusst Restart-flüchtig sein
# sollen (z. B. lokale Tests).
MTRACE_PERSISTENCE=sqlite
MTRACE_SQLITE_PATH=/var/lib/mtrace/m-trace.db

# Optionale SRT-Health-Quelle (RAK-41/RAK-42). Wenn leer/unset, ist
# der SRT-Health-Pfad inaktiv. Siehe docs/user/srt-health.md.
# MTRACE_SRT_SOURCE_URL=http://mediamtx:9997
# MTRACE_SRT_SOURCE_USER=
# MTRACE_SRT_SOURCE_PASS=
# MTRACE_SRT_PROJECT_ID=demo
# MTRACE_SRT_POLL_INTERVAL_SECONDS=5
# MTRACE_SRT_REQUIRED_BANDWIDTH_BPS=2000000

# -------------------------------------------------------------------
# Stream-Analyzer service (apps/analyzer-service, packages/stream-analyzer)
# -------------------------------------------------------------------
# Adresse, an der die API den Analyzer aufruft.
ANALYZER_BASE_URL=http://analyzer-service:7000

# Listen-Adresse des Analyzer-Service.
ANALYZER_LISTEN_HOST=0.0.0.0
ANALYZER_LISTEN_PORT=7000

# Lab-Default: erlaubt das Analysieren intern erreichbarer
# MediaMTX-Streams (RFC1918-IPs aus dem Compose-Bridge). In
# Produktions-Deployments NICHT setzen — der SSRF-Schutz blockiert
# private IPs sonst absichtlich (siehe docs/user/stream-analyzer.md
# §6).
ANALYZER_ALLOW_PRIVATE_NETWORKS=true

# -------------------------------------------------------------------
# Dashboard (apps/dashboard) — Public-Vars werden in den Browser
# geliefert, daher ausschließlich Demo-Werte.
# -------------------------------------------------------------------
PUBLIC_API_BASE_URL=http://localhost:8080
PUBLIC_API_TOKEN=demo-token
PUBLIC_HLS_URL=http://localhost:8888/teststream/index.m3u8
PUBLIC_PLAYER_COLLECTOR_ENDPOINT=http://localhost:8080/api/playback-events

# Dashboard-Demo-Route, die das HLS-Manifest direkt vom MediaMTX
# zieht.
MEDIAMTX_URL=http://mediamtx:8888

# -------------------------------------------------------------------
# Observability (opt-in, Profil "observability"). Ohne aktiviertes
# Profil bleiben diese leer — der OTel-SDK-Autoexport-Fallback
# liefert dann No-Op-Reader/-Exporter (siehe spec/architecture.md
# §5.3 und docs/user/local-development.md Troubleshooting).
# -------------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_PROTOCOL=
OTEL_TRACES_EXPORTER=
OTEL_METRICS_EXPORTER=

# Beispiel: OTel-Spans in stdout (RAK-10-Smoke).
# OTEL_TRACES_EXPORTER=console

# OTel-Collector-Config-Auswahl: leer = config.yaml (Debug-Exporter,
# kein Tempo). Für `make dev-tempo` setzt der Workflow das Var auf
# config-tempo.yaml.
COLLECTOR_CONFIG=config.yaml
