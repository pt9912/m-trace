{
  "schema_version": "1.0",
  "owner": "m-trace telemetry contract",
  "batch": {
    "schema_version_field": "schema_version",
    "events_field": "events",
    "session_boundaries_field": "session_boundaries",
    "min_events": 1,
    "max_events": 100,
    "max_session_boundaries": 20,
    "boundary_only_batches": false,
    "boundaries_must_match_event_partition": true,
    "max_body_bytes": 262144
  },
  "session_boundaries": {
    "optional": true,
    "kinds": [
      "network_signal_absent"
    ],
    "network_kinds": [
      "manifest",
      "segment"
    ],
    "adapters": [
      "hls.js",
      "native_hls",
      "unknown"
    ],
    "reasons_ref": "network_unavailable_reasons",
    "reason_pattern_ref": "network_unavailable_reason_pattern",
    "required_fields": [
      "kind",
      "project_id",
      "session_id",
      "network_kind",
      "adapter",
      "reason",
      "client_timestamp"
    ]
  },
  "network_unavailable_reasons_anchor": "spec/telemetry-model.md §1.4",
  "network_unavailable_reasons": [
    "native_hls_unavailable",
    "hlsjs_signal_unavailable",
    "browser_api_unavailable",
    "resource_timing_unavailable",
    "cors_timing_blocked",
    "service_worker_opaque"
  ],
  "network_unavailable_reason_pattern": "^[a-z0-9_]{1,64}$",
  "reserved_meta_keys": {
    "network.kind": {
      "type": "string",
      "values": [
        "manifest",
        "segment"
      ]
    },
    "network.detail_status": {
      "type": "string",
      "values": [
        "available",
        "network_detail_unavailable"
      ]
    },
    "network.unavailable_reason": {
      "type": "string",
      "values_ref": "network_unavailable_reasons",
      "pattern_ref": "network_unavailable_reason_pattern",
      "requires": {
        "network.detail_status": "network_detail_unavailable"
      },
      "on_requires_mismatch": "422"
    },
    "network.redacted_url": {
      "type": "string",
      "redacted_url": true
    },
    "timing.*": {
      "types": [
        "number",
        "rfc3339_string"
      ]
    },
    "webrtc.peer_connection_run_id": {
      "type": "string",
      "pattern": "^[a-z0-9_-]{1,64}$"
    },
    "webrtc.sample_id": {
      "type": "integer",
      "min": 0
    },
    "webrtc.connection_state": {
      "type": "string",
      "values": [
        "new",
        "connecting",
        "connected",
        "disconnected",
        "failed",
        "closed"
      ]
    },
    "webrtc.ice_state": {
      "type": "string",
      "values": [
        "new",
        "checking",
        "connected",
        "completed",
        "failed",
        "disconnected",
        "closed"
      ]
    },
    "webrtc.dtls_state": {
      "type": "string",
      "values": [
        "new",
        "connecting",
        "connected",
        "closed",
        "failed"
      ]
    },
    "webrtc.packets_lost": {
      "type": "integer",
      "min": 0
    },
    "webrtc.bytes_received": {
      "type": "integer",
      "min": 0
    },
    "webrtc.bytes_sent": {
      "type": "integer",
      "min": 0
    },
    "webrtc.error_code": {
      "type": "string",
      "values": [
        "whep_signaling_failed",
        "whep_sdp_invalid",
        "webrtc_no_tracks",
        "peer_connection_failed",
        "webrtc_destroyed_before_connected"
      ]
    },
    "webrtc.error_detail": {
      "type": "string",
      "max_length": 256
    }
  },
  "reserved_meta_namespace_webrtc": {
    "anchor": "spec/telemetry-model.md §1.4 / §3.5",
    "rule": "All `webrtc.*` keys must appear in the `reserved_meta_keys` allowlist above. Unknown `webrtc.*` keys are rejected with HTTP 422 and do not produce a `mtrace_webrtc_*` metric. Non-`webrtc.*` keys remain forward-compatible per existing additive-meta convention."
  },
  "event_names": [
    "manifest_loaded",
    "segment_loaded",
    "playback_started",
    "bitrate_switch",
    "rebuffer_started",
    "rebuffer_ended",
    "playback_error",
    "startup_time_measured",
    "metrics_sampled",
    "session_ended",
    "startup_completed"
  ]
}
