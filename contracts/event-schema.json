{
  "schema_version": "1.0",
  "owner": "m-trace telemetry contract",
  "batch": {
    "schema_version_field": "schema_version",
    "events_field": "events",
    "min_events": 1,
    "max_events": 100,
    "max_body_bytes": 262144
  },
  "event_names": [
    "manifest_loaded",
    "segment_loaded",
    "playback_started",
    "bitrate_switch",
    "rebuffer_started",
    "rebuffer_ended",
    "playback_error",
    "startup_time_measured",
    "metrics_sampled",
    "session_ended",
    "startup_completed"
  ]
}
