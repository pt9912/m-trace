{
  "name": "m-trace",
  "version": "0.3.0",
  "private": true,
  "packageManager": "pnpm@10.18.0",
  "engines": {
    "node": ">=22 <23",
    "pnpm": ">=10 <11"
  },
  "scripts": {
    "build": "pnpm -r --if-present run build",
    "test": "pnpm -r --if-present run test",
    "test:e2e": "playwright test",
    "lint": "pnpm -r --if-present run lint && node scripts/check-sdk-compat.mjs",
    "check": "pnpm -r --if-present run check",
    "m-trace": "node packages/stream-analyzer/dist/cli/main.cjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "hls.js": "^1.6.16",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  }
}
