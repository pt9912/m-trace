{
  "name": "@npm9912/stream-analyzer",
  "version": "0.6.0",
  "description": "HLS stream analyzer for the m-trace toolchain (manifest loading, playlist classification, segment-duration findings).",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pt9912/m-trace.git",
    "directory": "packages/stream-analyzer"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "m-trace": "./dist/cli/main.cjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts src/cli/main.ts --format esm,cjs --dts --clean",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit && eslint . && node scripts/check-boundaries.mjs && node scripts/check-public-api.mjs"
  },
  "devDependencies": {
    "@types/node": "22.12.0",
    "@vitest/coverage-v8": "4.1.5",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  }
}
