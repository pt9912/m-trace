{
  "name": "@m-trace/player-sdk",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs,iife --global-name MTracePlayerSDK --dts --clean",
    "test": "vitest run",
    "lint": "tsc --noEmit && node scripts/check-boundaries.mjs"
  },
  "peerDependencies": {
    "hls.js": "^1.6.0"
  },
  "devDependencies": {
    "hls.js": "1.6.16",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  }
}
