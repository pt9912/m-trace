# Spike workflow is Docker-only (see docs/planning/plan-spike.md §14.11 and
# docs/spike/0001-backend-stack.md §6.11). gradle-wrapper.jar and
# gradlew are NOT committed; the gradle:8.12-jdk21 build image
# brings Gradle directly. Local wrapper files (if a developer
# generates them via "gradle wrapper") are dev-only and stay
# uncommitted.
**/gradle/wrapper/

# ---------------------------------------------------------------------------
# Python (Skripte unter scripts/)
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]

# ---------------------------------------------------------------------------
# Docker
# ---------------------------------------------------------------------------
*.pid

# ---------------------------------------------------------------------------
# Local/temporary data
# ---------------------------------------------------------------------------
tmp/
.tmp/
*.bak

# StrykerJS-Mutation-Reports (generiert; mutation.yml lädt sie als
# Workflow-Artefakt hoch — das Go-Pendant liegt unter .tmp/mutation).
packages/player-sdk/reports/

# Spike-isolated dependency caches (see docs/planning/plan-spike.md §7.2):
.gomodcache/
.gradle-user-home/

# ---------------------------------------------------------------------------
# d-migrate Generator-Output (siehe ADR-0002 §8.2)
# ---------------------------------------------------------------------------
# `schema generate` schreibt einen Report neben das DDL. Das Report-
# File ist nicht-deterministisch (Timestamps, Zustand) und wird nicht
# committet; das DDL selbst bleibt unter Versionskontrolle.
apps/api/internal/storage/migrations/*.report.yaml
# Backup-/Editor-Reste neben SQL-Migrationen (`go:embed migrations/*.sql`
# greift `*.sql.bak` und `*.sql~` ohnehin nicht — Hygiene-Schutz, falls
# ein Editor lokal Backups schreibt).
apps/api/internal/storage/migrations/*.sql.bak
apps/api/internal/storage/migrations/*.sql~

# ---------------------------------------------------------------------------
# Security-Gates (plan-0.8.5 Tranche 1)
# ---------------------------------------------------------------------------
# `make image-scan` legt die Trivy-Vuln-DB unter `.security/.trivy-cache/`
# ab, damit lokale Wiederholungen sie nicht jedes Mal neu laden. Der
# Cache ist non-deterministisch und groß (mehrere hundert MB) — deshalb
# nur das Cache-Subverzeichnis ignorieren, nicht das ganze
# `.security/`-Verzeichnis (`vulnignore.yaml` muss committet bleiben).
.security/.trivy-cache/
# `.security/.trivyignore` wird aus `.security/vulnignore.yaml` per
# `scripts/render-trivyignore.sh` generiert; `make image-scan` ruft
# den Generator vor dem Trivy-Lauf auf. Source-of-truth ist
# `vulnignore.yaml` (mit `reason`/`expires`/`scope`-Audit-Feldern).
.security/.trivyignore

# ---------------------------------------------------------------------------
# Tooling state
# ---------------------------------------------------------------------------
.claude/
.codex
