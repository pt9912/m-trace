# =============================================================================
# m-trace .gitignore
#
# Covers both spike prototypes (Go and Micronaut/JVM), the planned TypeScript
# / pnpm / SvelteKit components, Docker tooling, common IDE state, and
# Claude Code session state.
# =============================================================================

# ---------------------------------------------------------------------------
# OS
# ---------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ---------------------------------------------------------------------------
# IDE / editors
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.iml
*.iws
*.ipr
.fleet/
.nb-gradle/
*.swp
*.swo
*~

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---------------------------------------------------------------------------
# Environment / secrets
# ---------------------------------------------------------------------------
.env
.env.local
.env.*.local
!.env.example

# ---------------------------------------------------------------------------
# Node.js / pnpm / TypeScript
# ---------------------------------------------------------------------------
node_modules/
.pnpm-store/
.pnp.*
dist/
out/
.cache/
.turbo/
.parcel-cache/
coverage/
*.tsbuildinfo
.eslintcache

# ---------------------------------------------------------------------------
# SvelteKit / Vite
# ---------------------------------------------------------------------------
.svelte-kit/
.vite/

# ---------------------------------------------------------------------------
# Go
# ---------------------------------------------------------------------------
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.prof
coverage.txt
coverage.out
vendor/

# ---------------------------------------------------------------------------
# JVM / Gradle / Maven / Micronaut
# ---------------------------------------------------------------------------
.gradle/
build/
target/
*.class
*.jar
*.war
*.ear
*.nar
hs_err_pid*
replay_pid*
.kotlin/

# Spike workflow is Docker-only (see docs/plan-spike.md §14.11 and
# docs/spike/0001-backend-stack.md §6.11). gradle-wrapper.jar and
# gradlew are NOT committed; the gradle:8.12-jdk21 build image
# brings Gradle directly. Local wrapper files (if a developer
# generates them via "gradle wrapper") are dev-only and stay
# uncommitted.
**/gradle/wrapper/

# ---------------------------------------------------------------------------
# Docker
# ---------------------------------------------------------------------------
*.pid

# ---------------------------------------------------------------------------
# Local/temporary data
# ---------------------------------------------------------------------------
tmp/
.tmp/
*.bak

# Spike-isolated dependency caches (see docs/plan-spike.md §7.2):
.gomodcache/
.gradle-user-home/

# ---------------------------------------------------------------------------
# Tooling state
# ---------------------------------------------------------------------------
.claude/
