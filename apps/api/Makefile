# m-trace API spike — Go variant
# Docker-only workflow per docs/planning/done/plan-spike.md §14.11.

IMAGE := m-trace-api-spike

# Coverage-Threshold für `make coverage-gate`. 90 % als Start, Ziel 95 %
# (siehe docs/user/quality.md §3). Über `make coverage-gate THRESHOLD=…`
# überschreibbar, ohne den Default-Pfad anzufassen.
THRESHOLD ?= 90

# `--no-cache-filter <stage>` zwingt BuildKit, die genannte Stage neu
# zu evaluieren, ohne die `deps`-Layer (Go-Module-Cache) zu verwerfen.
# Ohne diesen Filter konnte ein Stale-Layer-Hash früher Test-Failures
# maskieren — siehe Coverage-Doku.
NO_CACHE_FILTER_TEST     := --no-cache-filter test
NO_CACHE_FILTER_LINT     := --no-cache-filter lint
NO_CACHE_FILTER_COVERAGE := --no-cache-filter coverage

.PHONY: test lint build deps compile run arch-check coverage coverage-gate coverage-report clean schema-validate schema-generate

# d-migrate Container für Schema-Definition und DDL-Generierung
# (ADR-0002 §8.2). Build-/Dev-time-Werkzeug; das API-Image bleibt
# JDK-frei. Tag explizit gepinnt, damit der `Generated by …`-Header
# in V1__m_trace.sql stabil bleibt — `:latest` würde bei jedem
# d-migrate-Release einen schleichenden DDL-Diff erzeugen.
SCHEMA_DIR     := internal/storage
DMIGRATE_IMAGE := ghcr.io/pt9912/d-migrate:0.9.5

# Run unit + integration tests inside Docker.
test:
	docker build $(NO_CACHE_FILTER_TEST) --target test -t $(IMAGE):go-test .

# Run golangci-lint (Soll, plan §14.9 / §14.11).
lint:
	docker build $(NO_CACHE_FILTER_LINT) --target lint -t $(IMAGE):go-lint .

# Build the runtime image (distroless static).
build:
	docker build --target runtime -t $(IMAGE):go .

# Resolve dependencies only (used to size the deps cache layer, plan §7.2).
deps:
	docker build --no-cache --target deps -t $(IMAGE):go-deps .

# Compile-only feedback loop (no tests, no lint).
compile:
	docker build --target compile -t $(IMAGE):go-compile .

# Run the runtime container with port 8080 exposed.
run: build
	docker run --rm -p 8080:8080 --name m-trace-api-go $(IMAGE):go

# Architecture-Boundary-Test (siehe spec/architecture.md §3.4).
# Prüft, dass hexagon/ keine direkten Imports auf Adapter,
# OTel, Prometheus, database/sql oder net/http enthält und die
# Schichtengrenzen domain → application → port respektiert sind.
arch-check:
	docker run --rm -v "$(CURDIR):/src" -w /src golang:1.26 \
		bash scripts/check-architecture.sh

# Coverage-Pflicht-Gate (docs/user/quality.md §3): misst Coverage über
# hexagon/ und adapters/, druckt den per-Funktion-Report und fordert
# mindestens THRESHOLD % Total. Default-Threshold 90 %, Ziel 95 %.
# Override: `make coverage-gate THRESHOLD=92`.
coverage-gate:
	docker build $(NO_CACHE_FILTER_COVERAGE) \
		--target coverage \
		--build-arg COVERAGE_THRESHOLD=$(THRESHOLD) \
		-t $(IMAGE):go-coverage .

# Alias: gleicher Pfad wie das Gate, aber als „informational"-Form für
# Tageworkflow lesbar — derselbe Stage liefert per-Funktion-Report
# auf stdout, das Gate ist trotzdem aktiv.
coverage: coverage-gate

# Coverage-Report (HTML + Profil + Func-Text) in apps/api/build/coverage/
# extrahieren. Nutzt `--output type=local`, um die /out-Layer der
# coverage-Stage als Verzeichnis rauszuziehen.
coverage-report:
	mkdir -p build/coverage
	docker build $(NO_CACHE_FILTER_COVERAGE) \
		--target coverage-export \
		--build-arg COVERAGE_THRESHOLD=$(THRESHOLD) \
		--output type=local,dest=build/coverage \
		.
	@echo "coverage-report: build/coverage/coverage.html"

# Schema-YAML gegen d-migrate's neutrales Modell validieren — CI-Gate
# (ADR-0002 §8.2). Schlägt fehl, wenn Spalten/Indizes/Constraints
# d-migrate-Validation nicht bestehen.
schema-validate:
	docker run --rm -v "$(CURDIR)/$(SCHEMA_DIR):/work" \
		$(DMIGRATE_IMAGE) schema validate --source /work/schema.yaml

# Baseline-DDL aus schema.yaml für SQLite erzeugen (ADR-0002 §8.2),
# im Flyway-File-Format (`V<version>__<description>.sql`). `export
# flyway` produziert byte-deterministischen Output ohne Generated-
# Timestamp im Header — Re-Generation ohne Schema-Änderung erzeugt
# keinen git-Diff, keine Workaround-Pipeline nötig.
#
# `--version 1` legt die Initial-Version fest; spätere Schema-
# Evolutionen (V2+) sind hand-gepflegte Migrationen (oder via
# `d-migrate schema migrate`, sobald das Diff-basiert verfügbar ist).
# Re-Run dieses Targets überschreibt **nur** V1__m_trace.sql; hand-
# gepflegte V2+-Files bleiben unangetastet. d-migrate's export-flyway
# kennt keinen --force-Schalter, daher löscht das Target das alte
# Initial-File vor dem Lauf explizit.
schema-generate:
	rm -f $(SCHEMA_DIR)/migrations/V1__m_trace.sql
	docker run --rm -v "$(CURDIR)/$(SCHEMA_DIR):/work" \
		$(DMIGRATE_IMAGE) export flyway \
			--source /work/schema.yaml --target sqlite \
			--version 1 --output /work/migrations
	@echo "[schema-generate] DDL: apps/api/$(SCHEMA_DIR)/migrations/V1__m_trace.sql"

# Remove all spike-related images.
clean:
	-docker rmi $(IMAGE):go $(IMAGE):go-test $(IMAGE):go-lint $(IMAGE):go-compile $(IMAGE):go-deps $(IMAGE):go-coverage
