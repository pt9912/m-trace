{
  "name": "@npm9912/m-trace-dashboard",
  "version": "0.1.2",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "test": "svelte-kit sync && vitest run",
    "test:coverage": "svelte-kit sync && vitest run --coverage",
    "lint": "pnpm --filter @npm9912/player-sdk run build && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check": "pnpm --filter @npm9912/player-sdk run build && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json"
  },
  "dependencies": {
    "@npm9912/player-sdk": "workspace:*",
    "hls.js": "^1.6.16"
  },
  "devDependencies": {
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.58.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@testing-library/svelte": "^5.3.1",
    "@vitest/coverage-v8": "4.1.5",
    "jsdom": "^29.1.1",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.6",
    "vite": "^8.0.10",
    "vitest": "4.1.5"
  }
}
