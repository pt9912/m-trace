PUBLIC_API_BASE_URL=
# Token für die Read-Endpunkte (plan-0.4.0 §4.3). Muss zu einem
# bekannten Project im API-Resolver passen; Default-Lab-Setup nutzt
# `demo-token`.
PUBLIC_API_TOKEN=demo-token
PUBLIC_HLS_URL=http://localhost:8888/teststream/index.m3u8
PUBLIC_PLAYER_COLLECTOR_ENDPOINT=http://localhost:8080/api/playback-events
# WHEP-Endpoint für die /demo-webrtc-Route (plan-0.8.0 Tranche 2).
# Default zeigt auf das examples/webrtc/-Lab-Compose (Project
# mtrace-webrtc, Host-Port 8892). Wenn das Lab nicht läuft, schlägt
# der Adapter mit `whep_signaling_failed` fehl.
PUBLIC_WHEP_URL=http://localhost:8892/webrtc-test/whep
